      "parameters": {
        "jsCode": "// Añade imageBase64 para OpenAI Vision (desde binary.data)\nconst item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary;\nlet imageBase64 = '';\nif (binary?.data) {\n  const b = binary.data;\n  if (typeof b.data === 'string') imageBase64 = b.data;\n  else if (Buffer.isBuffer(b.data)) imageBase64 = b.data.toString('base64');\n}\nreturn [{ json: { ...json, imageBase64 }, binary: item.binary }];"
      },
