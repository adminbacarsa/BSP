    {
      "parameters": {
        "jsCode": "// Ventana 3 min: si no hay heartbeat en los últimos 3 min = desconectado. Una sola señal por cambio (desconectado → AGENT_OFFLINE, reconectado → AGENT_ONLINE).\nconst MINUTES_OFFLINE = 3;\nconst now = new Date();\nconst cutoffMs = now.getTime() - MINUTES_OFFLINE * 60 * 1000;\nconst state = $getWorkflowStaticData('global');\nif (!state.nvrStates) state.nvrStates = {};\nconst byNvr = {};\nfor (const item of $input.all()) {\n  const j = item.json || {};\n  const nvrId = (j.nvrId || j.NVR || '').toString().trim();\n  if (!nvrId) continue;\n  const tsStr = j.Ts || j.LastHeartbeat || j['Último'] || '';\n  let lastMs = NaN;\n  if (tsStr) {\n    const d = new Date(tsStr);\n    lastMs = isNaN(d.getTime()) ? 0 : d.getTime();\n  }\n  if (!byNvr[nvrId] || (lastMs && lastMs > (byNvr[nvrId] || 0))) byNvr[nvrId] = lastMs || byNvr[nvrId];\n}\nconst toSend = [];\nfor (const [nvrId, lastMs] of Object.entries(byNvr)) {\n  const isOffline = isNaN(lastMs) || lastMs < cutoffMs;\n  const prev = state.nvrStates[nvrId];\n  if (isOffline) {\n    if (prev !== 'offline') {\n      state.nvrStates[nvrId] = 'offline';\n      toSend.push({ json: { nvrId, eventTypeName: 'AGENT_OFFLINE', status: 'start', timestamp: now.toISOString() } });\n    }\n  } else {\n    if (prev === 'offline') {\n      state.nvrStates[nvrId] = 'online';\n      toSend.push({ json: { nvrId, eventTypeName: 'AGENT_ONLINE', status: 'start', timestamp: now.toISOString() } });\n    } else if (prev !== 'online') state.nvrStates[nvrId] = 'online';\n  }\n}\nreturn toSend;"
      },
