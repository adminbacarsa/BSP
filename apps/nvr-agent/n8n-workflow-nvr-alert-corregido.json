      "parameters": {
        "jsCode": "// Mapeo NVR -> IP y credenciales. Añadí aquí cada NVR (nvrId o nombre) con su IP y credenciales.\nconst body = $input.first().json.body || $input.first().json;\nconst map = {\n  'Bacar M102': { nvr_ip: '192.168.0.102', nvr_user: 'admin', nvr_pass: '18July75$' },\n  '8F0001CPAZ21EFD': { nvr_ip: '192.168.0.102', nvr_user: 'admin', nvr_pass: '18July75$' }\n};\nconst cfg = map[body.nvrId] || {};\nreturn [{ json: { ...($input.first().json), body, nvr_ip: cfg.nvr_ip || '', nvr_user: cfg.nvr_user || 'admin', nvr_pass: cfg.nvr_pass || '' } }];"
      },
